# Archon Configuration — template. Copy to .env and fill in.

# AI Assistant auth. When true, Archon reuses your local `claude /login`
# session instead of reading ANTHROPIC_API_KEY from env.
CLAUDE_USE_GLOBAL_AUTH=true

# Default AI Assistant (claude | codex)
DEFAULT_AI_ASSISTANT=claude

# Server (only used if you run the Archon server, not the CLI)
PORT=3000

# Concurrency
MAX_CONCURRENT_CONVERSATIONS=10

# ─── Optional, used by phase specs the runner executes ───────────────────
# Uncomment + fill in only if your phase specs need them.

# PERPLEXITY_API_KEY=
# ELEVENLABS_API_KEY=
# GITHUB_TOKEN=

# ─── Optional phase-runner overrides ─────────────────────────────────────
# Override where phase specs are loaded from / where status is tracked.
# PHASE_CMD_DIR=.claude/commands/phases
# STATUS_FILE_TEMPLATE=src/TARGET/phase-status.md
# ACTIVE_MARKER=.claude/active-target.txt
